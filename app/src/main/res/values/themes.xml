<resources>
    <!-- Base application theme. -->
    <style name="Theme.FoodRecipes" parent="Theme.Material3.DynamicColors.DayNight">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/material_dynamic_primary40</item>
        <item name="colorPrimaryVariant">@color/material_dynamic_primary80</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/material_dynamic_secondary40</item>
        <item name="colorSecondaryVariant">@color/material_dynamic_secondary80</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimary</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="chips" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="android:textColor">@color/design_default_color_on_primary</item>
    </style>
</resources>